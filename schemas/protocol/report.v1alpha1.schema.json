{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omca.dev/schemas/protocol/report.v1alpha1.schema.json",
  "title": "Report v1alpha1",
  "description": "The immutable report artifact human, JSON, TUI, and MCP projections all derive from (docs/architecture/reporting.md, especially §1 Trust Definition, §6 Drift Model, and §7 Root-cause Aggregation). spec.fingerprint is the digest a RepairProposal must be tied to (docs/architecture/reporting.md §11.3 omca_propose, docs/project/roadmap.md M4).",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "$ref": "common.v1alpha1.schema.json#/$defs/apiVersion" },
    "kind": { "const": "Report" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "worktree", "generatedAt"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "worktree": { "type": "string", "minLength": 1 },
        "generatedAt": { "type": "string" }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fingerprint", "drift"],
      "properties": {
        "fingerprint": {
          "$ref": "common.v1alpha1.schema.json#/$defs/digest",
          "description": "Digest of the committed inputs that produced this report; the value a RepairProposal.spec.reportFingerprint must match."
        },
        "planes": {
          "type": "object",
          "description": "docs/architecture/reporting.md §2, Reported State Planes. Counts/summary only at this scope; full plane content is queried on demand, not embedded in every Report.",
          "additionalProperties": false,
          "properties": {
            "native": { "type": "integer", "minimum": 0 },
            "observed": { "type": "integer", "minimum": 0 },
            "desired": { "type": "integer", "minimum": 0 },
            "current": { "type": "integer", "minimum": 0 },
            "pending": { "type": "integer", "minimum": 0 },
            "hostEffective": { "type": "integer", "minimum": 0 }
          }
        },
        "drift": {
          "type": "array",
          "description": "docs/architecture/reporting.md §6, Drift Model: each assertion names entity, field, expected/observed value, root cause, remediation, context cell, and evidence.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["entityId", "field", "category", "rootCause"],
            "properties": {
              "entityId": { "type": "string", "minLength": 1 },
              "field": { "type": "string", "minLength": 1 },
              "category": { "$ref": "common.v1alpha1.schema.json#/$defs/driftCategory" },
              "expected": {},
              "observed": {},
              "rootCause": { "type": "string", "minLength": 1 },
              "remediation": { "type": "string" },
              "contextCell": { "type": "string" },
              "evidenceLevel": { "$ref": "common.v1alpha1.schema.json#/$defs/evidenceLevel" },
              "guarantee": { "$ref": "common.v1alpha1.schema.json#/$defs/guaranteeLevel" }
            }
          }
        },
        "knowledgeStatus": {
          "type": "object",
          "description": "hostId -> knowledgeStatus, docs/knowledge/README.md §7.",
          "additionalProperties": { "$ref": "common.v1alpha1.schema.json#/$defs/knowledgeStatus" }
        }
      }
    }
  }
}
