{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omca.dev/schemas/domain/binding.v1alpha1.schema.json",
  "title": "Binding v1alpha1",
  "description": "Selects Profiles for a context. Does not establish host precedence (docs/product/requirements.md §4.2).",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "$ref": "common.v1alpha1.schema.json#/$defs/apiVersion" },
    "kind": { "const": "Binding" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["match", "profiles"],
      "properties": {
        "match": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repository"],
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "paths": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "profiles": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    }
  }
}
